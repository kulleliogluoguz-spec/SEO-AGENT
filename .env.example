# AI CMO OS — Environment Configuration
# Copy this file to .env and fill in values

# ─── Core ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-32-chars-minimum
LOG_LEVEL=INFO

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aicmo:aicmo_dev@localhost:5432/aicmo
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# ─── Local AI (PRIMARY — no external API required) ────────────────────────────
# The platform runs fully locally using Ollama. No external LLM API is needed.
# See docs/models/local-model-stack.md for model recommendations.
LLM_PRIMARY_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_DEFAULT_MODEL=qwen3:8b
LLM_FAST_MODEL=qwen3:8b
LLM_REASONING_MODEL=qwen3:8b
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ─── Vector Store (Qdrant) ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── vLLM (optional — for production GPU serving) ─────────────────────────────
# VLLM_BASE_URL=http://localhost:8001/v1
# VLLM_API_KEY=EMPTY

# ─── Anthropic (OPTIONAL — disabled by default) ───────────────────────────────
# The platform works without any external LLM API.
# Only enable if you want to optionally use Claude as a comparison/fallback.
ANTHROPIC_ENABLED=false
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Crawling ─────────────────────────────────────────────────────────────────
CRAWL_MAX_PAGES_DEFAULT=100
CRAWL_DELAY_SECONDS=1.0
CRAWL_USER_AGENT=AiCmoBot/1.0 (growth-analysis; polite-bot)
CRAWL_TIMEOUT_SECONDS=30
CRAWL_PLAYWRIGHT_ENABLED=true
# Comma-separated domain blocklist for SSRF protection
CRAWL_BLOCKED_DOMAINS=localhost,127.0.0.1,169.254.169.254,10.0.0.0/8

# ─── Temporal ─────────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=ai-cmo-os
TEMPORAL_TASK_QUEUE=ai-cmo-os-queue

# ─── Storage (Artifacts) ──────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage/artifacts
# For production S3-compatible:
# STORAGE_BACKEND=s3
# STORAGE_S3_BUCKET=ai-cmo-os-artifacts
# STORAGE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Social OAuth ────────────────────────────────────────────────────────────
# X / Twitter OAuth 2.0 PKCE — create app at developer.twitter.com
# Required scopes: tweet.write tweet.read users.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:3000/auth/callback/x

# Meta (Instagram + Meta Ads) — create app at developers.facebook.com
# Required permissions: instagram_basic instagram_content_publish pages_read_engagement
# For ads: ads_management ads_read
META_APP_ID=
META_APP_SECRET=
META_CALLBACK_URL=http://localhost:3000/auth/callback/meta

# Google OAuth + Google Ads — create at console.cloud.google.com
# Requires Google Ads API access + developer token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/callback/google
GOOGLE_ADS_DEVELOPER_TOKEN=

# ─── Connectors ───────────────────────────────────────────────────────────────
# GA4
GA4_MOCK_MODE=true
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GA4_PROPERTY_ID=properties/123456789

# Search Console
GSC_MOCK_MODE=true
# GSC_SITE_URL=https://example.com

# Slack
SLACK_MOCK_MODE=true
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# ─── Autonomy ─────────────────────────────────────────────────────────────────
AUTONOMY_DEFAULT_LEVEL=1
AUTONOMY_MAX_ALLOWED_LEVEL=3

# ─── Demo Mode ────────────────────────────────────────────────────────────────
DEMO_MODE=false
DEMO_USER_EMAIL=demo@aicmo.os
DEMO_USER_PASSWORD=Demo1234!

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI CMO OS
NEXT_PUBLIC_DEMO_MODE=false

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_GEO_AGENT=true
FEATURE_EXPERIMENTS=true
FEATURE_SOCIAL_PUBLISHING=false
FEATURE_CMS_PUBLISHING=false
FEATURE_ADVANCED_ANALYTICS=false
