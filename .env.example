# AI CMO OS — Environment Configuration
# Copy this file to .env and fill in values

# ─── Core ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-32-chars-minimum
LOG_LEVEL=INFO

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aicmo:aicmo_dev@localhost:5432/aicmo
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# ─── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_FAST_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Crawling ─────────────────────────────────────────────────────────────────
CRAWL_MAX_PAGES_DEFAULT=100
CRAWL_DELAY_SECONDS=1.0
CRAWL_USER_AGENT=AiCmoBot/1.0 (growth-analysis; polite-bot)
CRAWL_TIMEOUT_SECONDS=30
CRAWL_PLAYWRIGHT_ENABLED=true
# Comma-separated domain blocklist for SSRF protection
CRAWL_BLOCKED_DOMAINS=localhost,127.0.0.1,169.254.169.254,10.0.0.0/8

# ─── Temporal ─────────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=ai-cmo-os
TEMPORAL_TASK_QUEUE=ai-cmo-os-queue

# ─── Storage (Artifacts) ──────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage/artifacts
# For production S3-compatible:
# STORAGE_BACKEND=s3
# STORAGE_S3_BUCKET=ai-cmo-os-artifacts
# STORAGE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Connectors ───────────────────────────────────────────────────────────────
# GA4
GA4_MOCK_MODE=true
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GA4_PROPERTY_ID=properties/123456789

# Search Console
GSC_MOCK_MODE=true
# GSC_SITE_URL=https://example.com

# Slack
SLACK_MOCK_MODE=true
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# ─── Autonomy ─────────────────────────────────────────────────────────────────
AUTONOMY_DEFAULT_LEVEL=1
AUTONOMY_MAX_ALLOWED_LEVEL=3

# ─── Demo Mode ────────────────────────────────────────────────────────────────
DEMO_MODE=false
DEMO_USER_EMAIL=demo@aicmo.os
DEMO_USER_PASSWORD=Demo1234!

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI CMO OS
NEXT_PUBLIC_DEMO_MODE=false

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_GEO_AGENT=true
FEATURE_EXPERIMENTS=true
FEATURE_SOCIAL_PUBLISHING=false
FEATURE_CMS_PUBLISHING=false
FEATURE_ADVANCED_ANALYTICS=false
